# Normalize all text files to LF
* text=auto eol=lf

# Source files
*.cpp       text eol=lf
*.hpp       text eol=lf
*.h         text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.cmake     text eol=lf
*.gitignore text eol=lf
CMakeLists.txt text eol=lf

# Binary files — no conversion
*.exe binary
*.dll binary
*.a   binary
*.lib binary
*.obj binary
*.o   binary
